from __future__ import annotations

import argparse
import os
from pathlib import Path
import sys

ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(ROOT))

from sqlalchemy import create_engine, text
from sqlalchemy.pool import NullPool
from dotenv import load_dotenv

from importers import importar_itens_ods
from security import hash_password
from treba_importer import importar_zonas


def normalize_database_url(url: str) -> str:
    if url.startswith("postgres://"):
        url = "postgresql://" + url[len("postgres://"):]
    if url.startswith("postgresql://") and "+psycopg2" not in url:
        url = "postgresql+psycopg2://" + url[len("postgresql://"):]
    return url


def main():
    parser = argparse.ArgumentParser(description="Inicializa o banco Supabase/Postgres do SIMOC-BA.")
    parser.add_argument("--skip-zonas", action="store_true", help="Nao importa zonas da consulta publica do TRE-BA.")
    parser.add_argument("--skip-itens", action="store_true", help="Nao importa a planilha padrao ODS.")
    args = parser.parse_args()

    load_dotenv(ROOT / ".env")
    database_url = os.getenv("DATABASE_URL")
    if not database_url:
        raise SystemExit("Defina DATABASE_URL em .env ou no ambiente.")

    engine = create_engine(normalize_database_url(database_url), poolclass=NullPool, pool_pre_ping=True, future=True)
    schema_sql = (ROOT / "sql" / "schema.sql").read_text(encoding="utf-8")
    with engine.begin() as conn:
        for statement in [s.strip() for s in schema_sql.split(";") if s.strip()]:
            conn.execute(text(statement))

        perfis = [
            ("admin", "Administra sistema, usuários, zonas e parâmetros."),
            ("corregedoria_gestor", "Gestão da Corregedoria, dashboards e validações."),
            ("corregedoria_analista", "Análise e validação operacional."),
            ("chefe_cartorio", "Responsável pelo preenchimento da própria Zona Eleitoral."),
            ("substituto", "Substituto autorizado para preenchimento."),
            ("auditor", "Consulta e relatórios."),
        ]
        for nome, descricao in perfis:
            conn.execute(text("insert into perfis (nome, descricao) values (:nome, :descricao) on conflict (nome) do nothing"), {"nome": nome, "descricao": descricao})

        admin_email = os.getenv("ADMIN_EMAIL", "admin@tre-ba.jus.br").lower()
        admin_password = os.getenv("ADMIN_PASSWORD", "admin123")
        perfil_id = conn.execute(text("select id from perfis where nome='admin'")).scalar_one()
        conn.execute(
            text(
                """
                insert into usuarios (nome, email, senha_hash, perfil_id, ativo)
                values ('Administrador', :email, :senha, :perfil_id, true)
                on conflict (email) do nothing
                """
            ),
            {"email": admin_email, "senha": hash_password(str(admin_password)[:72]), "perfil_id": perfil_id},
        )

        if not args.skip_zonas:
            total_zonas = importar_zonas(conn)
            print(f"Zonas importadas/atualizadas: {total_zonas}")

        if not args.skip_itens:
            ods = ROOT / "PLANO DE AÇÃO - MONITORAMENTO CARTORÁRIO.ods"
            total_itens = importar_itens_ods(conn, ods)
            print(f"Itens da planilha processados: {total_itens}")

    print("Banco inicializado com sucesso.")


if __name__ == "__main__":
    main()
